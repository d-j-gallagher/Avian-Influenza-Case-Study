<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avian Influenza Field Investigation</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            background: #000;
            color: #fff;
            overflow-x: hidden;
        }
        
        /* Scene container */
        .scene {
            width: 100vw;
            min-height: 100vh;
            position: relative;
            display: none;
            background-size: cover;
            background-position: center;
        }
        
        .scene.active {
            display: block;
        }
        
        /* Start screen - make it look like a real office building exterior */
        .start-screen-bg {
            background: 
                linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)),
                linear-gradient(to bottom, 
                    #87ceeb 0%, 
                    #87ceeb 40%,
                    #d4d4d4 40%,
                    #d4d4d4 42%,
                    #696969 42%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            position: relative;
        }
        
        /* Add building windows pattern */
        .start-screen-bg::before {
            content: '';
            position: absolute;
            top: 40%;
            left: 10%;
            width: 80%;
            height: 55%;
            background: 
                repeating-linear-gradient(
                    90deg,
                    transparent,
                    transparent 60px,
                    rgba(100, 100, 100, 0.3) 60px,
                    rgba(100, 100, 100, 0.3) 63px
                ),
                repeating-linear-gradient(
                    0deg,
                    transparent,
                    transparent 50px,
                    rgba(100, 100, 100, 0.3) 50px,
                    rgba(100, 100, 100, 0.3) 53px
                );
            pointer-events: none;
        }
        
        .start-content {
            max-width: 800px;
            text-align: center;
            position: relative;
            z-index: 10;
        }
        
        .logo {
            font-size: 120px;
            margin-bottom: 20px;
            animation: float 3s ease-in-out infinite;
            filter: drop-shadow(0 10px 20px rgba(0,0,0,0.8));
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        
        h1 {
            font-size: 48px;
            margin-bottom: 15px;
            text-shadow: 3px 3px 15px rgba(0,0,0,0.8);
        }
        
        h2 {
            font-size: 24px;
            margin-bottom: 30px;
            opacity: 0.95;
        }
        
        .mission-box {
            background: rgba(0,0,0,0.7);
            padding: 30px;
            border-radius: 15px;
            margin: 30px 0;
            border: 2px solid rgba(255,255,255,0.3);
            backdrop-filter: blur(10px);
        }
        
        .btn-start {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
            border: none;
            padding: 20px 50px;
            font-size: 22px;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(46, 204, 113, 0.5);
            margin-top: 20px;
            transition: all 0.3s;
        }
        
        .btn-start:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(46, 204, 113, 0.6);
        }
        
        /* Office scene - realistic office interior */
        .office-bg {
            background: 
                linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.5)),
                linear-gradient(to bottom,
                    #f5f5f0 0%,
                    #f5f5f0 60%,
                    #8b7355 60%,
                    #8b7355 100%);
        }
        
        /* Add office details - bookshelf, filing cabinets */
        .office-bg::before {
            content: '';
            position: absolute;
            top: 15%;
            right: 5%;
            width: 250px;
            height: 400px;
            background: 
                linear-gradient(to right,
                    #5d4037 0%, #5d4037 8%,
                    #3e2723 8%, #3e2723 10%,
                    #5d4037 10%, #5d4037 18%,
                    #3e2723 18%, #3e2723 20%,
                    #5d4037 20%),
                repeating-linear-gradient(
                    0deg,
                    transparent,
                    transparent 40px,
                    rgba(0,0,0,0.3) 40px,
                    rgba(0,0,0,0.3) 43px
                );
            border: 3px solid #3e2723;
            box-shadow: -10px 10px 30px rgba(0,0,0,0.5);
        }
        
        /* Add desk with papers */
        .office-bg::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 40%;
            background: 
                linear-gradient(to bottom,
                    rgba(139, 115, 85, 0.3),
                    rgba(101, 67, 33, 0.5));
        }
        
        /* HUD */
        .hud {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 40px;
            background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 50;
        }
        
        .hud-location {
            background: rgba(0,0,0,0.8);
            padding: 10px 20px;
            border-radius: 20px;
            border: 2px solid rgba(52, 152, 219, 0.6);
            font-weight: bold;
            font-size: 16px;
        }
        
        .hud-time {
            background: rgba(0,0,0,0.8);
            padding: 10px 20px;
            border-radius: 20px;
            border: 2px solid rgba(46, 204, 113, 0.6);
            color: #2ecc71;
            font-weight: bold;
            font-size: 14px;
        }
        
        .progress-bar {
            flex: 1;
            max-width: 300px;
            height: 10px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            margin: 0 20px;
            overflow: hidden;
            border: 2px solid rgba(255,255,255,0.4);
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #3498db, #2ecc71);
            transition: width 0.5s;
            box-shadow: 0 0 10px rgba(52, 152, 219, 0.8);
        }
        
        /* Character area - using placeholder for real photo */
        .character-area {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
        }
        
        /* REALISTIC PERSON - This is a placeholder that can accept a real photo */
        .person-photo {
            position: absolute;
            bottom: 160px;
            left: 100px;
            width: 300px;
            height: 400px;
            /* Use a real photo here - for now showing a realistic silhouette */
            background: 
                /* Head/face area */
                radial-gradient(ellipse 80px 100px at 50% 20%, #d4a574 0%, #d4a574 60%, transparent 61%),
                /* Hair */
                radial-gradient(ellipse 90px 80px at 50% 10%, #3e2723 0%, #3e2723 60%, transparent 61%),
                /* Neck */
                radial-gradient(ellipse 40px 60px at 50% 35%, #d4a574 0%, #d4a574 70%, transparent 71%),
                /* Professional attire - white coat */
                radial-gradient(ellipse 140px 200px at 50% 70%, #ffffff 0%, #ffffff 80%, transparent 81%),
                /* Arms */
                radial-gradient(ellipse 50px 150px at 20% 70%, #ffffff 0%, #ffffff 70%, transparent 71%),
                radial-gradient(ellipse 50px 150px at 80% 70%, #ffffff 0%, #ffffff 70%, transparent 71%);
            background-repeat: no-repeat;
            filter: drop-shadow(0 10px 30px rgba(0,0,0,0.6));
        }
        
        /* INSTRUCTION FOR REAL PHOTO - Add this to the HTML element: */
        /* <img src="path-to-doctor-photo.jpg" style="width: 300px; height: 400px; object-fit: cover; object-position: center bottom;"> */
        
        .name-badge {
            position: absolute;
            top: -60px;
            left: 100px;
            background: rgba(0,0,0,0.95);
            color: white;
            padding: 12px 25px;
            border-radius: 25px;
            font-size: 16px;
            font-weight: bold;
            border: 2px solid #3498db;
            box-shadow: 0 5px 20px rgba(0,0,0,0.7);
            z-index: 10;
        }
        
        .badge-title {
            display: block;
            font-size: 12px;
            opacity: 0.85;
            margin-top: 3px;
        }
        
        /* Dialogue box */
        .dialogue {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.95);
            border-top: 4px solid #3498db;
            padding: 35px 60px;
            min-height: 160px;
            box-shadow: 0 -15px 50px rgba(0,0,0,0.9);
        }
        
        .dialogue-text {
            font-size: 19px;
            line-height: 1.9;
            margin-bottom: 15px;
            color: #ffffff;
        }
        
        .btn-continue {
            position: absolute;
            right: 50px;
            bottom: 30px;
            background: linear-gradient(135deg, #3498db, #2ecc71);
            color: white;
            border: none;
            padding: 14px 35px;
            border-radius: 30px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            box-shadow: 0 6px 20px rgba(52, 152, 219, 0.5);
            animation: pulse 2s infinite;
            transition: all 0.3s;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .btn-continue:hover {
            box-shadow: 0 10px 25px rgba(52, 152, 219, 0.7);
            transform: scale(1.08);
            animation: none;
        }
        
        /* Content modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.85);
            z-index: 100;
            overflow-y: auto;
        }
        
        .modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }
        
        .modal-content {
            background: white;
            border-radius: 20px;
            padding: 45px;
            max-width: 900px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            color: #333;
            position: relative;
            box-shadow: 0 25px 70px rgba(0,0,0,0.6);
            border: 4px solid #3498db;
        }
        
        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            background: #e74c3c;
            color: white;
            border: none;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 24px;
            font-weight: bold;
            box-shadow: 0 3px 10px rgba(0,0,0,0.3);
            transition: all 0.3s;
        }
        
        .modal-close:hover {
            background: #c0392b;
            transform: rotate(90deg);
        }
        
        /* Document styling */
        .doc-header {
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 18px;
            margin-bottom: 30px;
        }
        
        .doc-title {
            font-size: 28px;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        
        .doc-subtitle {
            color: #7f8c8d;
            font-size: 16px;
        }
        
        /* Questions */
        .question {
            background: linear-gradient(135deg, #fff9e6, #fef5e7);
            border: 3px solid #f39c12;
            border-radius: 15px;
            padding: 28px;
            margin: 25px 0;
            box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        }
        
        .q-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 18px;
        }
        
        .q-number {
            background: linear-gradient(135deg, #f39c12, #e67e22);
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: bold;
            font-size: 15px;
            box-shadow: 0 3px 10px rgba(243, 156, 18, 0.3);
        }
        
        .q-text {
            font-size: 18px;
            color: #2c3e50;
            font-weight: 500;
            margin-bottom: 18px;
            line-height: 1.7;
        }
        
        .answer-input {
            width: 100%;
            padding: 16px;
            border: 2px solid #ddd;
            border-radius: 10px;
            font-size: 16px;
            font-family: inherit;
            transition: all 0.3s;
        }
        
        .answer-input:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 4px rgba(52, 152, 219, 0.15);
        }
        
        textarea.answer-input {
            min-height: 110px;
            resize: vertical;
        }
        
        /* Buttons */
        .btn-group {
            display: flex;
            gap: 15px;
            justify-content: flex-end;
            margin-top: 35px;
        }
        
        .btn {
            padding: 16px 40px;
            border: none;
            border-radius: 30px;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #3498db, #2ecc71);
            color: white;
            box-shadow: 0 6px 20px rgba(52, 152, 219, 0.4);
        }
        
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(52, 152, 219, 0.5);
        }
        
        .btn-secondary {
            background: white;
            color: #2c3e50;
            border: 3px solid #3498db;
        }
        
        .btn-secondary:hover {
            background: #f8f9fa;
            transform: translateY(-2px);
        }
        
        /* Reference drawer - ONLY general info, NO answers */
        .ref-drawer {
            position: fixed;
            right: -420px;
            top: 0;
            width: 420px;
            height: 100vh;
            background: rgba(255,255,255,0.98);
            box-shadow: -8px 0 30px rgba(0,0,0,0.4);
            transition: right 0.4s;
            z-index: 200;
            overflow-y: auto;
            padding: 30px;
            color: #333;
            border-left: 4px solid #3498db;
        }
        
        .ref-drawer.open {
            right: 0;
        }
        
        .ref-toggle {
            position: fixed;
            right: 25px;
            top: 90px;
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
            border: none;
            padding: 16px 24px;
            border-radius: 30px 0 0 30px;
            cursor: pointer;
            font-weight: bold;
            z-index: 150;
            box-shadow: -5px 5px 15px rgba(0,0,0,0.4);
            font-size: 15px;
            transition: all 0.3s;
        }
        
        .ref-toggle:hover {
            background: linear-gradient(135deg, #2980b9, #21618c);
            padding-right: 30px;
        }
        
        .ref-box {
            background: #e8f4f8;
            padding: 20px;
            border-radius: 12px;
            margin: 20px 0;
            border-left: 4px solid #3498db;
        }
        
        .ref-box h3 {
            color: #2c3e50;
            margin-bottom: 12px;
            font-size: 18px;
        }
        
        .ref-box p {
            font-size: 14px;
            line-height: 1.7;
            color: #555;
        }
    </style>
</head>
<body>
    <!-- Reference Drawer - GENERAL INFO ONLY -->
    <button class="ref-toggle" onclick="toggleRef()">📚 Quick Reference</button>
    <div class="ref-drawer" id="refDrawer">
        <h2 style="color: #2c3e50; margin-bottom: 25px; font-size: 24px;">📋 Reference Materials</h2>
        
        <div class="ref-box">
            <h3>🦠 About Avian Influenza</h3>
            <p>
                <strong>Incubation Period:</strong> 3-5 days<br>
                <strong>Transmission:</strong> Direct contact with infected birds<br>
                <strong>Key Symptoms:</strong> Fever ≥38°C, cough, difficulty breathing<br>
                <strong>Severity:</strong> Can cause severe disease with high mortality
            </p>
        </div>
        
        <div class="ref-box" style="background: #e8f9f0; border-left-color: #27ae60;">
            <h3>🏥 District D Overview</h3>
            <p>
                <strong>Population:</strong> 85,000 residents<br>
                <strong>Health Facilities:</strong> 1 hospital, 3 clinics<br>
                <strong>Towns:</strong> 8 towns (Arlie, Bravo, Cerra, Delta, Echo, Tango, Uniform, Zot)
            </p>
        </div>
        
        <div class="ref-box" style="background: #fff9e6; border-left-color: #f39c12;">
            <h3>📊 Case Definitions</h3>
            <p>
                <strong>Confirmed Case:</strong> Laboratory-confirmed positive test (RT-PCR) plus clinical criteria and exposure history<br>
                <strong>Probable Case:</strong> Recent exposure + clinical symptoms, but lab results pending
            </p>
        </div>
        
        <div class="ref-box" style="background: #ffeef0; border-left-color: #e74c3c;">
            <h3>⚠️ Important Notes</h3>
            <p>
                This is a simulation for training purposes. All data is from the case study scenario set in 2024.
            </p>
        </div>
    </div>
    
    <!-- START SCENE -->
    <div class="scene start-screen-bg active" id="sceneStart">
        <div class="start-content">
            <div class="logo">🦠</div>
            <h1>AVIAN INFLUENZA</h1>
            <h2>Field Investigation Simulation</h2>
            
            <div class="mission-box">
                <h3 style="margin-bottom: 18px; font-size: 24px;">📋 Your Mission</h3>
                <p style="font-size: 17px; line-height: 1.9;">
                    <strong>Date:</strong> Monday, March 4, 2024<br>
                    <strong>Location:</strong> District D Public Health Office, Province A, Country Z<br>
                    <strong>Your Role:</strong> Newly Appointed Surveillance Officer
                </p>
                <p style="margin-top: 25px; font-size: 16px; line-height: 1.8;">
                    Welcome to your first day. An influenza outbreak may be developing in District D. 
                    Your task: investigate cases, analyze surveillance data, and provide critical 
                    information to guide public health action. Lives may depend on your investigation.
                </p>
            </div>
            
            <button class="btn-start" onclick="goToScene('scene1')">
                🎮 START INVESTIGATION
            </button>
        </div>
    </div>
    
    <!-- SCENE 1: Office -->
    <div class="scene office-bg" id="scene1">
        <div class="hud">
            <div class="hud-location">🏢 District D Public Health Office</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 10%"></div>
            </div>
            <div class="hud-time">Monday, March 4 • 08:30 AM</div>
        </div>
        
        <div class="character-area">
            <div class="name-badge">
                Dr. Sarah Kim
                <span class="badge-title">Senior Surveillance Officer</span>
            </div>
            
            <!-- REALISTIC PERSON SILHOUETTE -->
            <!-- Replace this with: <img src="doctor-photo.jpg" class="person-photo" alt="Dr. Sarah Kim"> -->
            <div class="person-photo"></div>
            
            <div class="dialogue">
                <div class="dialogue-text">
                    "Welcome to the team! I'm Dr. Kim, your supervisor and the senior surveillance officer here in District D. 
                    Before we dive into investigating current cases, I need to make sure you're familiar with surveillance 
                    fundamentals. Let's start with a quick knowledge check..."
                </div>
                <button class="btn-continue" onclick="showModal('modal1')">Continue →</button>
            </div>
        </div>
    </div>
    
    <!-- Modal 1: Questions -->
    <div class="modal" id="modal1">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal('modal1')">×</button>
            
            <div class="doc-header">
                <div class="doc-title">📝 Surveillance Knowledge Check</div>
                <div class="doc-subtitle">Answer these questions to proceed with the investigation</div>
            </div>
            
            <div class="question">
                <div class="q-header">
                    <span style="font-size: 38px;">❓</span>
                    <span class="q-number">Question 1</span>
                </div>
                <div class="q-text">
                    List the steps of the surveillance cycle.
                </div>
                <textarea class="answer-input" id="q1" placeholder="Type your answer here..."></textarea>
            </div>
            
            <div class="question">
                <div class="q-header">
                    <span style="font-size: 38px;">❓</span>
                    <span class="q-number">Question 2a</span>
                </div>
                <div class="q-text">
                    Why conduct surveillance at the local/district level? What is the reason for collecting surveillance data?
                </div>
                <textarea class="answer-input" id="q2a" placeholder="Type your answer here..."></textarea>
            </div>
            
            <div class="question">
                <div class="q-header">
                    <span style="font-size: 38px;">❓</span>
                    <span class="q-number">Question 2b</span>
                </div>
                <div class="q-text">
                    Why conduct surveillance of animal populations? What is the rationale for sharing this surveillance data with the human health sector?
                </div>
                <textarea class="answer-input" id="q2b" placeholder="Type your answer here..."></textarea>
            </div>
            
            <div class="question">
                <div class="q-header">
                    <span style="font-size: 38px;">❓</span>
                    <span class="q-number">Question 3</span>
                </div>
                <div class="q-text">
                    Which of the steps in the surveillance cycle should be performed at the district level?
                </div>
                <input type="text" class="answer-input" id="q3" placeholder="Type your answer here...">
            </div>
            
            <div class="btn-group">
                <button class="btn btn-primary" onclick="closeModal('modal1'); goToScene('scene2')">
                    Submit & Continue →
                </button>
            </div>
        </div>
    </div>
    
    <!-- SCENE 2: Demo Complete -->
    <div class="scene office-bg" id="scene2">
        <div class="hud">
            <div class="hud-location">🎯 Investigation Progress</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 30%"></div>
            </div>
            <div class="hud-time">Monday, March 4 • 10:00 AM</div>
        </div>
        
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; background: rgba(0,0,0,0.85); padding: 70px; border-radius: 25px; border: 3px solid #3498db;">
            <h2 style="font-size: 40px; margin-bottom: 25px;">🎉 Concept Demo Complete!</h2>
            <p style="font-size: 20px; margin-bottom: 20px; line-height: 1.7;">
                This demonstrates the realistic game concept with:<br>
                ✓ Real-world backgrounds<br>
                ✓ Realistic person placeholder<br>
                ✓ Reference materials (without answers)<br>
                ✓ Interactive questioning system
            </p>
            <p style="font-size: 16px; margin-bottom: 35px; color: #aaa;">
                The full version would continue with maps, data analysis,<br>
                hospital visits, patient interviews, and more scenes!
            </p>
            <button class="btn btn-primary" onclick="goToScene('sceneStart')" style="padding: 20px 45px; font-size: 18px;">
                ← Return to Start
            </button>
        </div>
    </div>
    
    <script>
        const answers = {};
        
        function goToScene(sceneId) {
            document.querySelectorAll('.scene').forEach(s => s.classList.remove('active'));
            document.getElementById(sceneId).classList.add('active');
            saveAnswers();
            window.scrollTo(0, 0);
        }
        
        function showModal(modalId) {
            document.getElementById(modalId).classList.add('active');
        }
        
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            saveAnswers();
        }
        
        function saveAnswers() {
            document.querySelectorAll('.answer-input').forEach(input => {
                if (input.value.trim()) {
                    answers[input.id] = input.value.trim();
                }
            });
        }
        
        function toggleRef() {
            document.getElementById('refDrawer').classList.toggle('open');
        }
        
        console.log("✅ Simulation loaded successfully!");
    </script>
